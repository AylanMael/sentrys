rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function myUid() { return request.auth.uid; }

    // User profile / membership (V1: 1 tenant par user, doc id = uid)
    match /tenantUsers/{uid} {
      allow create: if signedIn() && uid == myUid();
      allow read: if signedIn() && uid == myUid();
      // Empêche un user de s'auto-promouvoir
      allow update: if signedIn() && uid == myUid()
        && request.resource.data.role == resource.data.role
        && request.resource.data.tenantId == resource.data.tenantId;
      allow delete: if false;
    }

    // Tenants
    match /tenants/{tenantId} {
      // Création permise seulement si le user a déjà son tenantUsers/{uid}
      allow create: if signedIn()
        && exists(/databases/$(database)/documents/tenantUsers/$(myUid()))
        && get(/databases/$(database)/documents/tenantUsers/$(myUid())).data.tenantId == tenantId;

      allow read: if signedIn()
        && exists(/databases/$(database)/documents/tenantUsers/$(myUid()))
        && get(/databases/$(database)/documents/tenantUsers/$(myUid())).data.tenantId == tenantId;

      // (pour l’instant) pas d’update/delete côté client
      allow update, delete: if false;
    }

    // Tout le reste interdit pour l’instant
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
