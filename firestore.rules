rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================
       Helpers
    ========================= */

    function signedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }

    function tuPath() {
      return /databases/$(database)/documents/tenantUsers/$(uid());
    }

    function hasTU() {
      return signedIn() && exists(tuPath());
    }

    function tu() {
      return get(tuPath());
    }

    function myTenantId() {
      return hasTU() ? tu().data.tenantId : null;
    }

    function myRole() {
      return hasTU() ? tu().data.role : null;
    }

    function isSuperAdmin() {
      return hasTU() && myRole() == "super_admin";
    }

    function isOwner() {
      return hasTU() && myRole() == "owner";
    }

    function isAdmin() {
      return hasTU() && myRole() in ["super_admin", "owner", "admin"];
    }

    function isManager() {
      return hasTU() && myRole() in ["super_admin", "owner", "admin", "manager"];
    }

    function isViewer() {
      return hasTU() && myRole() == "viewer";
    }

    function isAgent() {
      return hasTU() && myRole() == "agent";
    }

    function isClient() {
      return hasTU() && myRole() == "client";
    }

    function canReadBackoffice() {
      return hasTU() && myRole() in ["super_admin", "owner", "admin", "manager", "viewer"];
    }

    function canManagePlanning() {
      return hasTU() && myRole() in ["super_admin", "owner", "admin", "manager"];
    }

    function sameTenantOnCreate() {
      return hasTU()
        && ("tenantId" in request.resource.data)
        && request.resource.data.tenantId == myTenantId();
    }

    function sameTenantResource() {
      return hasTU()
        && ("tenantId" in resource.data)
        && resource.data.tenantId == myTenantId();
    }

    function forbidChange(keys) {
      return !request.resource.data.diff(resource.data).changedKeys().hasAny(keys);
    }

    /* =========================
       Sites helpers
    ========================= */

    function sitePath(siteId) {
      return /databases/$(database)/documents/sites/$(siteId);
    }

    function siteExists(siteId) {
      return (siteId is string) && exists(sitePath(siteId));
    }

    function siteSameTenant(siteId) {
      return siteExists(siteId)
        && get(sitePath(siteId)).data.tenantId == myTenantId();
    }

    // Assignation site :
    // - accessUids
    // - ou legacy managerIds / agentIds
    function isAssignedToSite(siteId) {
      return hasTU()
        && siteExists(siteId)
        && get(sitePath(siteId)).data.tenantId == myTenantId()
        && (
          (
            ("accessUids" in get(sitePath(siteId)).data)
            && (get(sitePath(siteId)).data.accessUids is list)
            && get(sitePath(siteId)).data.accessUids.hasAny([uid()])
          )
          ||
          (
            ("managerIds" in get(sitePath(siteId)).data)
            && (get(sitePath(siteId)).data.managerIds is list)
            && get(sitePath(siteId)).data.managerIds.hasAny([uid()])
          )
          ||
          (
            ("agentIds" in get(sitePath(siteId)).data)
            && (get(sitePath(siteId)).data.agentIds is list)
            && get(sitePath(siteId)).data.agentIds.hasAny([uid()])
          )
        );
    }

    function accessUidsIsUnion(data) {
      return ("managerIds" in data)
        && ("agentIds" in data)
        && ("accessUids" in data)
        && (data.managerIds is list)
        && (data.agentIds is list)
        && (data.accessUids is list)
        && data.accessUids.hasAll(data.managerIds)
        && data.accessUids.hasAll(data.agentIds)
        && data.managerIds.concat(data.agentIds).hasAll(data.accessUids);
    }

    /* =========================
       tenantUsers
       Recommandation :
       création côté backend uniquement
    ========================= */

    match /tenantUsers/{userId} {

      allow create: if false;

      allow read: if signedIn()
        && (
          userId == uid()
          || (isManager() && resource.data.tenantId == myTenantId())
        );

      // self update : pas le droit de modifier uid / role / tenantId
      allow update: if signedIn()
        && userId == uid()
        && forbidChange(["uid", "role", "tenantId", "createdAt", "createdBy"]);

      // admin-like : gestion des users du tenant
      allow update: if isAdmin()
        && resource.data.tenantId == myTenantId()
        && forbidChange(["uid", "tenantId", "createdAt", "createdBy"]);

      allow delete: if false;
    }

    /* =========================
       tenants
       Recommandation :
       création côté backend uniquement
    ========================= */

    match /tenants/{tenantId} {

      allow create: if false;

      allow read: if hasTU() && tenantId == myTenantId();

      allow update: if isAdmin()
        && tenantId == myTenantId()
        && forbidChange(["createdBy", "createdAt"]);

      allow delete: if false;
    }

    /* =========================
       sites
    ========================= */

    match /sites/{id} {

      allow create: if canManagePlanning()
        && sameTenantOnCreate()
        && request.resource.data.name is string
        && request.resource.data.name.size() > 1
        && request.resource.data.isActive is bool
        && accessUidsIsUnion(request.resource.data)
        && request.resource.data.managerIds.hasAny([uid()]);

      allow read: if sameTenantResource()
        && (
          canReadBackoffice()
          || isAssignedToSite(id)
        );

      allow update: if sameTenantResource()
        && canManagePlanning()
        && forbidChange(["tenantId", "createdAt", "createdBy"])
        && accessUidsIsUnion(request.resource.data);

      allow delete: if isAdmin() && sameTenantResource();
    }

    /* =========================
       agents
    ========================= */

    match /agents/{id} {

      allow create: if canManagePlanning()
        && sameTenantOnCreate()
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.status in ["active", "inactive", "disabled"];

      allow read: if sameTenantResource()
        && (
          canReadBackoffice()
          || isAgent()
        );

      allow update: if canManagePlanning()
        && sameTenantResource()
        && forbidChange(["tenantId", "createdAt", "createdBy"]);

      allow delete: if isAdmin() && sameTenantResource();
    }

    /* =========================
       incidents
    ========================= */

    match /incidents/{id} {

      allow create: if hasTU()
        && sameTenantOnCreate()
        && request.resource.data.siteId is string
        && siteSameTenant(request.resource.data.siteId)
        && (
          canReadBackoffice()
          || isAssignedToSite(request.resource.data.siteId)
        )
        && request.resource.data.description is string
        && request.resource.data.status in ["Ouvert", "Clos", "ouvert", "clos"]
        && request.resource.data.severity in [
          "Faible", "Moyenne", "Élevée",
          "faible", "moyenne", "elevee", "élevée"
        ];

      allow read: if sameTenantResource()
        && (
          canReadBackoffice()
          || isAssignedToSite(resource.data.siteId)
        );

      allow update: if sameTenantResource()
        && (
          (
            canManagePlanning()
            && forbidChange(["tenantId", "createdAt", "createdBy", "siteId"])
          )
          ||
          (
            isAgent()
            && isAssignedToSite(resource.data.siteId)
            && forbidChange([
              "tenantId",
              "createdAt",
              "createdBy",
              "siteId",
              "severity",
              "siteName"
            ])
          )
        );

      allow delete: if isAdmin() && sameTenantResource();

      match /comments/{commentId} {

        function incidentOk() {
          return hasTU()
            && exists(/databases/$(database)/documents/incidents/$(id))
            && get(/databases/$(database)/documents/incidents/$(id)).data.tenantId == myTenantId();
        }

        function canSeeIncidentSite() {
          return canReadBackoffice()
            || isAssignedToSite(
              get(/databases/$(database)/documents/incidents/$(id)).data.siteId
            );
        }

        allow read: if incidentOk() && canSeeIncidentSite();

        allow create: if incidentOk()
          && canSeeIncidentSite()
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;

        allow update, delete: if false;
      }
    }

    /* =========================
       vacations
    ========================= */

    match /vacations/{id} {

      allow create: if canManagePlanning()
        && sameTenantOnCreate()
        && request.resource.data.siteId is string
        && siteSameTenant(request.resource.data.siteId)
        && request.resource.data.startAt is timestamp
        && request.resource.data.endAt is timestamp
        && request.resource.data.requiredAgents is int;

      allow read: if sameTenantResource()
        && (
          canReadBackoffice()
          || isAssignedToSite(resource.data.siteId)
        );

      allow update: if sameTenantResource()
        && canManagePlanning()
        && forbidChange(["tenantId", "createdAt", "createdBy"]);

      allow delete: if isAdmin() && sameTenantResource();
    }

    /* =========================
       assignments
    ========================= */

    match /assignments/{id} {

      allow create: if canManagePlanning()
        && sameTenantOnCreate()
        && request.resource.data.agentId is string
        && request.resource.data.vacationId is string
        && request.resource.data.siteId is string
        && siteSameTenant(request.resource.data.siteId);

      allow read: if sameTenantResource()
        && (
          canReadBackoffice()
          || resource.data.agentId == uid()
        );

      allow update: if sameTenantResource()
        && (
          (
            canManagePlanning()
            && forbidChange(["tenantId", "createdAt", "createdBy", "agentId", "vacationId"])
          )
          ||
          (
            // Agent self-update (e.g. for simple status changes if not via API)
            // Note: If all status changes go through API, we can keep this false or very restricted.
            // For now, let's allow it if it's the assigned agent.
            resource.data.agentId == uid()
            && forbidChange(["tenantId", "createdAt", "createdBy", "agentId", "vacationId", "siteId"])
          )
        );

      allow delete: if isAdmin() && sameTenantResource();
    }

    /* =========================
       Default deny
    ========================= */

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
