rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function myUid() { return request.auth.uid; }

    // V1: 1 tenant par user, docId = uid
    match /tenantUsers/{uid} {
      allow create: if signedIn() && uid == myUid();
      allow read: if signedIn() && uid == myUid();

      // Empêche auto-promotion + changement tenantId
      allow update: if signedIn()
        && uid == myUid()
        && request.resource.data.role == resource.data.role
        && request.resource.data.tenantId == resource.data.tenantId;

      allow delete: if false;
    }

    match /tenants/{tenantId} {
      allow create: if signedIn()
        && exists(/databases/$(database)/documents/tenantUsers/$(myUid()))
        && get(/databases/$(database)/documents/tenantUsers/$(myUid())).data.tenantId == tenantId;

      allow read: if signedIn()
        && exists(/databases/$(database)/documents/tenantUsers/$(myUid()))
        && get(/databases/$(database)/documents/tenantUsers/$(myUid())).data.tenantId == tenantId;

      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
