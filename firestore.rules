rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // A user can create their own profile during the initial signup.
    match /tenantUsers/{userId} {
      // CREATE: A user can create their own profile document.
      // This is part of the atomic signup flow.
      allow create: if isOwner(userId)
                    // We must be setting the role to 'Admin' for the initial user.
                    && request.resource.data.role == 'Admin'
                    // The document UID must match the authenticated user.
                    && request.resource.data.uid == userId;

      // READ: A user can only read their own profile.
      allow read: if isOwner(userId);

      // UPDATE: A user can update their own profile, but cannot change their tenant or role.
      allow update: if isOwner(userId)
                    && request.resource.data.tenantId == resource.data.tenantId
                    && request.resource.data.role == resource.data.role;

      // DELETE: Not allowed from the client.
      allow delete: if false;
    }

    // A tenant document can be created by the user who is designated as its creator.
    match /tenants/{tenantId} {
      // CREATE: A user can create a tenant if they are the creator.
      // This is part of the atomic signup flow.
      allow create: if signedIn()
                    && request.resource.data.createdBy == request.auth.uid;

      // READ: A user can read a tenant doc if they are a member of that tenant.
      allow read: if signedIn()
                  && get(/databases/$(database)/documents/tenantUsers/$(request.auth.uid)).data.tenantId == tenantId;

      // UPDATE, DELETE: Not allowed from the client.
      allow update, delete: if false;
    }

    // Default deny all other access.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
