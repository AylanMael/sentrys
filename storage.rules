rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userTenantId() {
      return firestore.get(
        /databases/(default)/documents/tenantUsers/$(request.auth.uid)
      ).data.tenantId;
    }

    match /tenants/{tenantId}/agents/{agentId}/{allPaths=**} {
      allow read, write: if signedIn() && userTenantId() == tenantId;
    }
  }
}
